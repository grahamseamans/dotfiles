{
  "name": "go-sequence dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0",
      "GOLANG_VERSION": "1.25.4"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "golang.go"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[go]": {
          "editor.defaultFormatter": "golang.go",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "go.useLanguageServer": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=${localWorkspaceFolderBasename}-bashhistory,target=/commandhistory,type=volume",
    "source=${localWorkspaceFolderBasename}-claude-config,target=/home/node/.claude,type=volume",
    "source=${localWorkspaceFolderBasename}-gocache,target=/home/node/.cache/go-build,type=volume",
    "source=${localWorkspaceFolderBasename}-gomodcache,target=/home/node/go/pkg/mod,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "GOPATH": "/home/node/go",
    "GOCACHE": "/home/node/.cache/go-build",
    "GOMODCACHE": "/home/node/go/pkg/mod",
    "CGO_ENABLED": "1",
    "XAI_API_KEY": "${localEnv:XAI_API_KEY}",
    "MOUSER_API_KEY": "${localEnv:MOUSER_API_KEY}",
    "DIGIKEY_CLIENT_ID": "${localEnv:DIGIKEY_CLIENT_ID}",
    "DIGIKEY_CLIENT_SECRET": "${localEnv:DIGIKEY_CLIENT_SECRET}",
    "DIGIKEY_USE_SANDBOX": "${localEnv:DIGIKEY_USE_SANDBOX}",
    "WEATHER_LAT": "${localEnv:WEATHER_LAT}",
    "WEATHER_LON": "${localEnv:WEATHER_LON}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN_GOSEQUENCE}",
    "GH_TOKEN": "${localEnv:GITHUB_TOKEN_GOSEQUENCE}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postAttachCommand": "cd ~/dotfiles && git pull --ff-only && ./install.sh"
}
